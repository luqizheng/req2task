{
  "name": "req2task",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:web": "npx tsx scripts/dev-web.ts",
    "dev:service": "npx tsx scripts/dev-service.ts",
    "dev:infra": "docker-compose -f docker-compose.dev.yml --env-file ./apps/service/.env up -d",
    "dev:infra:stop": "docker-compose -f docker-compose.dev.yml --env-file ./apps/service/.env down",
    "check:env": "npx ts-node scripts/check-env.ts",
    "build": "pnpm -r run build",
    "build:web": " pnpm -F @req2task/web run build ",
    "build:service": "pnpm -F @req2task/service  build ",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "test:web": "pnpm --filter @req2task/web test",
    "test:e2e:web": "pnpm --filter @req2task/web test:e2e",
    "test:e2e": "pnpm --filter @req2task/service test:e2e",
    "test:all": "pnpm run test && pnpm run test:e2e",
    "db:migration:generate": "ts-node scripts/migration-generate.ts",
    "db:migration:run": "ts-node scripts/migration-run.ts",
    "db:migration:revert": "ts-node scripts/migration-revert.ts",
    "db:migration:show": "ts-node scripts/migration-show.ts",
    "db:reset": "ts-node scripts/db-reset.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "tsx": "^4.7.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/pg": "^8.20.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "pg": "^8.11.0",
    "typescript": "^5.3.0"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
