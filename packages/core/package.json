{
  "name": "@req2task/core",
  "version": "0.1.0",
  "type": "commonjs",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./entities": {
      "types": "./dist/entities/index.d.ts",
      "import": "./dist/entities/index.js",
      "require": "./dist/entities/index.js"
    },
    "./entities/*": {
      "types": "./dist/entities/*.d.ts",
      "import": "./dist/entities/*.js",
      "require": "./dist/entities/*.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js",
      "require": "./dist/services/index.js"
    },
    "./bo": {
      "types": "./dist/bo/index.d.ts",
      "import": "./dist/bo/index.js",
      "require": "./dist/bo/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "@req2task/dto": "workspace:*",
    "axios": "^1.6.0",
    "typeorm": "^0.3.19"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}